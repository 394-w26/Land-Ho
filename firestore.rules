rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Boats ──────────────────────────────────
    match /boats/{boatId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerUid == request.auth.uid;
    }

    // ── Booking Requests ───────────────────────
    match /bookingRequests/{requestId} {
      allow read: if request.auth != null
                  && (resource.data.hostUid == request.auth.uid
                      || resource.data.applicantUid == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.applicantUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.hostUid == request.auth.uid;
    }

    // ── User Public Profiles ───────────────────
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // ── Captain Onboarding Profiles ────────────
    match /captainProfiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // ── Sailor Onboarding Profiles ─────────────
    match /sailorProfiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // ── Instructor Requests ────────────────────
    match /instructorRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.sailorUid == request.auth.uid;
      allow update: if request.auth != null
                    && (resource.data.sailorUid == request.auth.uid
                        || resource.data.matchedInstructorUid == request.auth.uid);
    }

    // ── Conversations (Sailor ↔ Captain chat) ──
    match /conversations/{conversationId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participantUids;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participantUids;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participantUids;

      // ── Messages subcollection ─────────────
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids;
        allow create: if request.auth != null
                      && request.resource.data.senderUid == request.auth.uid
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids;
      }
    }
  }
}
